# plasmidBin/ports.env — Canonical TCP port assignments
#
# These ports are the ecosystem standard for TCP-based deployment:
#   - Remote gate deployment (SSH)
#   - ADB port forwarding (Android/Pixel)
#   - WAN firewall rules
#   - Cross-gate federation probing
#   - benchScale Docker topologies
#
# On the same machine, primals prefer Unix domain sockets (UDS)
# discovered by biomeOS SocketDiscoveryEngine.
#
# Override any port: BEARDOG_PORT=9100 ./start_primal.sh beardog

BEARDOG_PORT="${BEARDOG_PORT:-9100}"
SONGBIRD_PORT="${SONGBIRD_PORT:-9200}"
NESTGATE_PORT="${NESTGATE_PORT:-9300}"
TOADSTOOL_PORT="${TOADSTOOL_PORT:-9400}"
SQUIRREL_PORT="${SQUIRREL_PORT:-9500}"
PETALTONGUE_PORT="${PETALTONGUE_PORT:-9600}"
LUDOSPRING_PORT="${LUDOSPRING_PORT:-9650}"
BIOMEOS_PORT="${BIOMEOS_PORT:-9800}"

# Composition definitions — which primals form each atomic
COMP_TOWER="beardog songbird"
COMP_COMPUTE="beardog songbird toadstool"
COMP_NODE="beardog songbird toadstool squirrel"
COMP_NEST="beardog songbird nestgate"
COMP_FULL="beardog songbird nestgate toadstool squirrel biomeos petaltongue"
COMP_STORYTELLING="beardog songbird biomeos squirrel petaltongue"

primals_for_composition() {
    case "$1" in
        tower)        echo "$COMP_TOWER" ;;
        compute)      echo "$COMP_COMPUTE" ;;
        node)         echo "$COMP_NODE" ;;
        nest)         echo "$COMP_NEST" ;;
        full)         echo "$COMP_FULL" ;;
        storytelling) echo "$COMP_STORYTELLING" ;;
        *)            echo "ERROR: Unknown composition: $1" >&2; return 1 ;;
    esac
}

port_for_primal() {
    case "$1" in
        beardog)      echo "$BEARDOG_PORT" ;;
        songbird)     echo "$SONGBIRD_PORT" ;;
        nestgate)     echo "$NESTGATE_PORT" ;;
        toadstool)    echo "$TOADSTOOL_PORT" ;;
        squirrel)     echo "$SQUIRREL_PORT" ;;
        biomeos)      echo "$BIOMEOS_PORT" ;;
        petaltongue)  echo "$PETALTONGUE_PORT" ;;
        ludospring)   echo "$LUDOSPRING_PORT" ;;
        *)            echo "0" ;;
    esac
}
